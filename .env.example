# Bedsonline (Hotelbeds) — your existing B2B credentials
HOTELBEDS_API_KEY=your_api_key_here
HOTELBEDS_SECRET=your_secret_here

# Acerooms — your agent account credentials
ACEROOMS_USERNAME=your_acerooms_username
ACEROOMS_PASSWORD=your_acerooms_password

# Amadeus — register free at amadeus.com/developers
AMADEUS_API_KEY=your_amadeus_key
AMADEUS_API_SECRET=your_amadeus_secret

# Currency — free at openexchangerates.org
FX_APP_ID=your_fx_app_id

# Search settings
DESTINATION=AMS
DEPARTURE_CITIES=LON,MAN,EDI,BRS
NIGHT_DURATIONS=2,3,4
SEARCH_DAYS_AHEAD=365
OCCUPANCY_ADULTS=2

# Deal alert — fires email if any package drops below this price (GBP)
ALERT_THRESHOLD_GBP=200

# Email delivery — uses Gmail SMTP or any SMTP server
EMAIL_FROM=your@email.com
EMAIL_TO=team@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your_app_password

# Output folder — where Excel files are saved
OUTPUT_DIR=C:\Users\Mansi Singh\Downloads\Projects\fare-matrix\data
